# --- CORE AI CREDENTIALS ---
# Used for the AI Executive Verdict in reports
OPENROUTER_API_KEY=your_openrouter_key_here

# --- NOTIFICATIONS ---
# Get these from @BotFather and @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- HYPERLIQUID SUB-ACCOUNT ARCHITECTURE ---
# These are the isolated accounts for the Multi-Portfolio Model.
# Each sub-account margin pool is independent.

# Sub-Account A: 15m Scalping
MAINNET_PRIVATE_KEY_15M=0x_your_sub_account_a_private_key
MAINNET_ACCOUNT_ADDRESS_15M=0x_your_sub_account_a_address

# Sub-Account B: 1h Trend Trading
MAINNET_PRIVATE_KEY_1H=0x_your_sub_account_b_private_key
MAINNET_ACCOUNT_ADDRESS_1H=0x_your_sub_account_b_address

# Sub-Account C: 4h Swing Trading
MAINNET_PRIVATE_KEY_4H=0x_your_sub_account_c_private_key
MAINNET_ACCOUNT_ADDRESS_4H=0x_your_sub_account_c_address

# DEFAULT / FALLBACK CREDENTIALS
MAINNET_PRIVATE_KEY=0x_your_default_private_key
MAINNET_ACCOUNT_ADDRESS=0x_your_default_address

# --- AWS / S3 STORAGE ---
# Used for saving/loading LightGBM models and S3 model downloads in bot_executor
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_BUCKET=your_s3_bucket_name
AWS_REGION=us-east-1

# --- TESTNET (Optional) ---
# Used if bot/config.py is set to TESTNET_MODE = True
TESTNET_PRIVATE_KEY=0x_your_testnet_key
TESTNET_ACCOUNT_ADDRESS=0x_your_testnet_address
