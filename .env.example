# =================================================================
# 🚀 ALPHA FACTORY - CONFIGURATION
# =================================================================

# --- 🔌 HYPERLIQUID CREDENTIALS ---
# You can use a single account for all timeframes, or specific sub-accounts.
# If _4H, _1H, or _15M are missing, the bot falls back to the MAINNET keys.

# Main/Default Account
MAINNET_PRIVATE_KEY=your_main_private_key_here
MAINNET_ACCOUNT_ADDRESS=your_main_account_address_here

# (Optional) Sub-Account for 4H Macro
# MAINNET_PRIVATE_KEY_4H=your_sub_account_key_here
# MAINNET_ACCOUNT_ADDRESS_4H=your_sub_account_address_here

# (Optional) Sub-Account for 15M Sniper
# MAINNET_PRIVATE_KEY_15M=your_sub_account_key_here
# MAINNET_ACCOUNT_ADDRESS_15M=your_sub_account_address_here

# --- 🧪 TESTNET (Optional) ---
TESTNET_MODE=False
TESTNET_PRIVATE_KEY=your_testnet_key
TESTNET_ACCOUNT_ADDRESS=your_testnet_address

# --- ☁️ INFRASTRUCTURE ---
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
AWS_BUCKET=your_s3_bucket_name

# --- 📢 NOTIFICATIONS ---
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- 🤖 MODEL SETTINGS ---
# Percentage of capital to allocate per basket (1.0 = 100% of sub-account)
RISK_MULTIPLIER=1.0
BASKET_N=5
HYSTERESIS_FACTOR=0.1
